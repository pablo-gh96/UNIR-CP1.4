pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                git branch: 'develop', url: 'https://github.com/pablo-gh96/UNIR-CP1.4.git'

                sh '''
                    rm -rf config-repo
                    rm -f samconfig.toml

                    git clone --branch staging https://github.com/pablo-gh96/todo-list-aws-config.git config-repo
                    cp config-repo/samconfig.toml .
                    rm -rf config-repo
                '''

                stash name: 'source-code', includes: '**/*'
            }
        }

        stage('Static Test') {
            agent { label 'static-agent' }

            steps {
                unstash 'source-code'

                sh '''
                    hostname
                    whoami
                    pwd

                    export PATH=$HOME/.local/bin:$PATH

                    flake8 --exit-zero --max-line-length 100 --format=pylint src > flake8.out

                    bandit --exit-zero -r src -f custom -o bandit.out \
                    --msg-template "{abspath}:{line}:[{test_id}] {msg}"
                '''

                recordIssues tools: [
                    flake8(pattern: 'flake8.out'),
                    pyLint(name: 'Bandit', pattern: 'bandit.out')
                ]
            }
        }

        stage('Deploy') {
            steps {
                unstash 'source-code'

                sh '''
                    hostname
                    whoami
                    pwd

                    sam build
                    sam validate --region us-east-1
                    sam deploy --config-env staging --resolve-s3 --no-confirm-changeset --no-fail-on-empty-changeset
                '''
            }
        }

        stage('Rest Test') {
            agent { label 'rest-agent' }

            steps {
                unstash 'source-code'

                sh '''
                    hostname
                    whoami
                    pwd

                    export PATH=$HOME/.local/bin:$PATH

                    export BASE_URL=$(aws cloudformation describe-stacks \
                      --stack-name todo-list-aws-staging \
                      --region us-east-1 \
                      --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                      --output text)

                    pytest --junitxml=result-rest.xml test/integration
                '''

                junit 'result-rest.xml'
            }
        }

        stage('Promote') {
            steps {
                unstash 'source-code'

                withCredentials([usernamePassword(
                    credentialsId: '8ab42dad-d14c-4c58-bcac-5475e9e9d34f',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        hostname
                        whoami
                        pwd

                        git config user.email "jenkins@local"
                        git config user.name "Jenkins"

                        git fetch origin
                        git checkout master
                        git pull origin master
                        git merge develop

                        git push https://${GIT_USER}:${GIT_TOKEN}@github.com/pablo-gh96/UNIR-CP1.4.git master
                    '''
                }
            }
        }
    }
}